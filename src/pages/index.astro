---
import Base from '../layouts/Base.astro';
import { app, copy, site } from '../data/site.js';

const locale = site.defaultLocale;
const text = copy[locale].home;
const heroShots = app.screenshots.slice(0, 3);
---

<Base
  title={text.pageTitle}
  description={text.pageDescription}
  image={app.screenshots[0].src}
  locale={locale}
  translations={copy}
  titleKey="home.pageTitle"
  descriptionKey="home.pageDescription"
>
  <main class="page">
    <section class="hero panel">
      <div class="hero-copy">
        <img
          class="hero-icon"
          src={app.icon}
          alt={text.hero.iconAlt}
          width="512"
          height="512"
          data-i18n-attrs={JSON.stringify({ alt: 'home.hero.iconAlt' })}
        />
        <h1>{app.name}</h1>
        <p class="hero-text" data-i18n="home.hero.tagline">{text.hero.tagline}</p>

        <div class="button-row hero-actions">
          {text.hero.ctas.map((cta, index) =>
            cta.href ? (
              <a
                class={`button ${cta.variant === 'primary' ? 'button-primary' : 'button-secondary'}`}
                href={cta.href}
                rel="noopener noreferrer"
                target="_blank"
                data-i18n={`home.hero.ctas.${index}.label`}
              >
                {cta.label}
              </a>
            ) : (
              <span class="button button-secondary button-disabled" aria-disabled="true" data-i18n={`home.hero.ctas.${index}.label`}>
                {cta.label}
              </span>
            ),
          )}
        </div>
      </div>

      <div class="hero-art">
        <div class="art-glow art-glow-a"></div>
        <div class="art-glow art-glow-b"></div>

        <button
          class="art-card art-card-back-left"
          type="button"
          data-lightbox-src={heroShots[1].src}
          data-lightbox-alt={text.screenshots[1]}
          data-i18n-attrs={JSON.stringify({ 'data-lightbox-alt': 'home.screenshots.1' })}
        >
          <img
            src={heroShots[1].src}
            alt={text.screenshots[1]}
            width={heroShots[1].width}
            height={heroShots[1].height}
            loading="eager"
            data-i18n-attrs={JSON.stringify({ alt: 'home.screenshots.1' })}
          />
        </button>

        <button
          class="art-card art-card-main"
          type="button"
          data-lightbox-src={heroShots[0].src}
          data-lightbox-alt={text.screenshots[0]}
          data-i18n-attrs={JSON.stringify({ 'data-lightbox-alt': 'home.screenshots.0' })}
        >
          <img
            src={heroShots[0].src}
            alt={text.screenshots[0]}
            width={heroShots[0].width}
            height={heroShots[0].height}
            loading="eager"
            fetchpriority="high"
            data-i18n-attrs={JSON.stringify({ alt: 'home.screenshots.0' })}
          />
        </button>

        <button
          class="art-card art-card-back-right"
          type="button"
          data-lightbox-src={heroShots[2].src}
          data-lightbox-alt={text.screenshots[2]}
          data-i18n-attrs={JSON.stringify({ 'data-lightbox-alt': 'home.screenshots.2' })}
        >
          <img
            src={heroShots[2].src}
            alt={text.screenshots[2]}
            width={heroShots[2].width}
            height={heroShots[2].height}
            loading="eager"
            data-i18n-attrs={JSON.stringify({ alt: 'home.screenshots.2' })}
          />
        </button>
      </div>
    </section>

    <section class="section screenshots">
      <h2 data-i18n="home.sections.screenshots">{text.sections.screenshots}</h2>
      <div class="shot-rail">
        {app.screenshots.map((shot, index) => (
          <button
            class="shot panel"
            type="button"
            data-lightbox-src={shot.src}
            data-lightbox-alt={text.screenshots[index]}
            data-i18n-attrs={JSON.stringify({ 'data-lightbox-alt': `home.screenshots.${index}` })}
          >
            <img
              src={shot.src}
              alt={text.screenshots[index]}
              width={shot.width}
              height={shot.height}
              loading="lazy"
              data-i18n-attrs={JSON.stringify({ alt: `home.screenshots.${index}` })}
            />
          </button>
        ))}
      </div>
    </section>

    <section class="section features">
      <h2 data-i18n="home.sections.features">{text.sections.features}</h2>
      <div class="feature-grid">
        {text.features.map((feature, index) => (
          <article class={`feature panel ${feature.variant === 'soon' ? 'feature-soon' : ''}`}>
            {feature.badge && (
              <span class="feature-badge" data-i18n={`home.features.${index}.badge`}>
                {feature.badge}
              </span>
            )}
            <h3 data-i18n={`home.features.${index}.title`}>{feature.title}</h3>
            <p data-i18n={`home.features.${index}.description`}>{feature.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <footer class="footer">
    <a class="footer-brand" href="/" aria-label={text.footerBrandAria} data-i18n-attrs={JSON.stringify({ 'aria-label': 'home.footerBrandAria' })}>
      <img src={app.icon} alt="" width="512" height="512" />
      <span>{app.name}</span>
    </a>
    <nav class="footer-links" aria-label={text.footerNavAria} data-i18n-attrs={JSON.stringify({ 'aria-label': 'home.footerNavAria' })}>
      <a href={site.supportPath} data-i18n="home.footer.support">{text.footer.support}</a>
      <a href={site.privacyPath} data-i18n="home.footer.privacy">{text.footer.privacy}</a>
    </nav>
  </footer>

  <div class="lightbox" id="lightbox" aria-hidden="true">
    <button class="lightbox-backdrop" type="button" aria-label="Kapat" data-lightbox-close data-i18n-attrs={JSON.stringify({ 'aria-label': 'common.close' })}></button>
    <figure class="lightbox-panel" role="dialog" aria-label={text.lightboxDialog} data-i18n-attrs={JSON.stringify({ 'aria-label': 'home.lightboxDialog' })}>
      <button class="lightbox-close" type="button" aria-label="Kapat" data-lightbox-close data-i18n-attrs={JSON.stringify({ 'aria-label': 'common.close' })}>×</button>
      <img class="lightbox-image" alt="" />
    </figure>
  </div>

  <script>
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = lightbox?.querySelector('.lightbox-image');
    let returnFocus = null;

    const closeLightbox = () => {
      if (!lightbox || !lightboxImage) return;

      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('lightbox-open');
      lightboxImage.removeAttribute('src');
      lightboxImage.alt = '';

      if (returnFocus instanceof HTMLElement) {
        returnFocus.focus();
      }

      returnFocus = null;
    };

    const openLightbox = (trigger) => {
      if (!lightbox || !lightboxImage) return;

      const src = trigger.getAttribute('data-lightbox-src');
      const alt = trigger.getAttribute('data-lightbox-alt') || '';

      if (!src) return;

      returnFocus = trigger instanceof HTMLElement ? trigger : null;
      lightboxImage.src = src;
      lightboxImage.alt = alt;
      lightbox.setAttribute('aria-hidden', 'false');
      lightbox.classList.add('is-open');
      document.documentElement.classList.add('lightbox-open');

      const closeButton = lightbox.querySelector('[data-lightbox-close]');
      if (closeButton instanceof HTMLElement) {
        closeButton.focus();
      }
    };

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Element)) return;

      const trigger = event.target.closest('[data-lightbox-src]');
      if (trigger instanceof HTMLElement) {
        event.preventDefault();
        openLightbox(trigger);
        return;
      }

      if (event.target.closest('[data-lightbox-close]')) {
        event.preventDefault();
        closeLightbox();
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox?.classList.contains('is-open')) {
        closeLightbox();
      }
    });
  </script>
</Base>

<style>
  .page {
    display: grid;
    gap: 28px;
  }

  .hero {
    position: relative;
    overflow: hidden;
    display: grid;
    gap: 28px;
    padding: 22px;
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    inset: auto;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(28px);
    opacity: 0.8;
  }

  .hero::before {
    width: 320px;
    height: 320px;
    left: -120px;
    top: -110px;
    background: rgba(24, 213, 225, 0.12);
  }

  .hero::after {
    width: 340px;
    height: 340px;
    right: -140px;
    bottom: -140px;
    background: rgba(47, 167, 255, 0.1);
  }

  .hero-copy,
  .hero-art {
    position: relative;
    z-index: 1;
  }

  .hero-copy {
    display: grid;
    align-content: center;
    gap: 16px;
  }

  .hero-icon {
    width: 60px;
    height: 60px;
    border-radius: 16px;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.22);
  }

  .hero h1 {
    margin: 0;
    font-size: clamp(3.4rem, 11vw, 6.6rem);
    line-height: 0.94;
    letter-spacing: -0.07em;
  }

  .hero-text {
    margin: 0;
    max-width: 22ch;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.45;
    letter-spacing: -0.02em;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .button-disabled {
    opacity: 0.58;
    cursor: default;
  }

  .hero-art {
    position: relative;
    min-height: 430px;
    border-radius: 28px;
  }

  .art-glow {
    position: absolute;
    inset: auto;
    border-radius: 999px;
    filter: blur(32px);
    pointer-events: none;
  }

  .art-glow-a {
    width: 260px;
    height: 260px;
    left: 8%;
    top: 10%;
    background: rgba(24, 213, 225, 0.18);
  }

  .art-glow-b {
    width: 280px;
    height: 280px;
    right: 4%;
    bottom: 8%;
    background: rgba(47, 167, 255, 0.18);
  }

  .art-card {
    position: absolute;
    margin: 0;
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
    border-radius: 28px;
    overflow: hidden;
    box-shadow: 0 28px 70px rgba(0, 0, 0, 0.36);
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    cursor: zoom-in;
    font: inherit;
    color: inherit;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .art-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .art-card-main {
    width: min(78%, 320px);
    left: 50%;
    bottom: 0;
    transform: translateX(-50%);
    z-index: 3;
  }

  .art-card-back-left {
    width: min(42%, 190px);
    left: 6%;
    top: 14%;
    transform: rotate(-8deg);
    opacity: 0.92;
    z-index: 2;
  }

  .art-card-back-right {
    width: min(42%, 190px);
    right: 3%;
    top: 22%;
    transform: rotate(8deg);
    opacity: 0.92;
    z-index: 2;
  }

  .hero-art:hover .art-card-main {
    transform: translateX(-50%) translateY(-8px);
  }

  .hero-art:hover .art-card-back-left {
    transform: translateY(-6px) rotate(-10deg);
  }

  .hero-art:hover .art-card-back-right {
    transform: translateY(-6px) rotate(10deg);
  }

  .section {
    display: grid;
    gap: 16px;
  }

  .section h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .shot-rail {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: min(78vw, 340px);
    gap: 16px;
    overflow-x: auto;
    padding-bottom: 8px;
    scroll-snap-type: x mandatory;
    scroll-padding-inline: 1px;
    overscroll-behavior-x: contain;
  }

  .shot {
    margin: 0;
    padding: 0;
    appearance: none;
    -webkit-appearance: none;
    overflow: hidden;
    border-radius: 28px;
    scroll-snap-align: start;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.28);
    cursor: zoom-in;
    font: inherit;
    color: inherit;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .shot img {
    width: 100%;
    height: auto;
    display: block;
  }

  .shot:hover {
    transform: translateY(-4px);
    box-shadow: 0 26px 56px rgba(0, 0, 0, 0.36);
  }

  .shot:focus-visible,
  .art-card:focus-visible,
  .lightbox-close:focus-visible,
  .lightbox-backdrop:focus-visible {
    outline: 2px solid rgba(47, 167, 255, 0.9);
    outline-offset: 3px;
  }

  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 50;
    display: grid;
    place-items: center;
    padding: 20px;
    background: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(16px);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 180ms ease,
      visibility 180ms ease;
  }

  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: zoom-out;
  }

  .lightbox-panel {
    position: relative;
    margin: 0;
    width: min(92vw, 440px);
  }

  .lightbox-image {
    display: block;
    width: 100%;
    height: auto;
    max-height: 88vh;
    object-fit: contain;
    border-radius: 28px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 34px 90px rgba(0, 0, 0, 0.56);
    background: rgba(10, 12, 16, 0.96);
  }

  .lightbox-close {
    position: absolute;
    top: -14px;
    right: -14px;
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(10, 12, 16, 0.94);
    color: var(--text);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
  }

  html.lightbox-open {
    overflow: hidden;
  }

  .feature-grid {
    display: grid;
    gap: 14px;
  }

  .feature {
    padding: 18px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 24px;
  }

  .feature-badge {
    display: inline-flex;
    align-items: center;
    padding: 5px 10px;
    margin-bottom: 14px;
    border-radius: 999px;
    border: 1px solid rgba(24, 213, 225, 0.24);
    background: rgba(24, 213, 225, 0.08);
    color: var(--accent);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .feature-soon {
    background:
      radial-gradient(circle at top right, rgba(24, 213, 225, 0.12), transparent 42%),
      rgba(255, 255, 255, 0.03);
    border-color: rgba(24, 213, 225, 0.2);
  }

  .feature h3 {
    margin: 0 0 8px;
    font-size: 18px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }

  .feature p {
    margin: 0;
    color: var(--muted);
    line-height: 1.65;
  }

  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding-top: 8px;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-size: 15px;
    font-weight: 700;
  }

  .footer-brand img {
    width: 28px;
    height: 28px;
    border-radius: 9px;
  }

  .footer-links {
    display: inline-flex;
    gap: 14px;
    color: var(--muted);
    font-size: 14px;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  @media (min-width: 760px) {
    .hero {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
      align-items: center;
      gap: 12px;
      padding: 28px;
      min-height: 620px;
    }

    .hero-copy {
      max-width: 560px;
    }

    .hero-text {
      max-width: 22ch;
    }

    .hero-art {
      min-height: 560px;
    }

    .feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .feature-soon {
      grid-column: 1 / -1;
    }

    .shot-rail {
      grid-auto-columns: min(38vw, 320px);
    }
  }

  @media (min-width: 980px) {
    .page {
      gap: 36px;
    }
  }

  @media (max-width: 620px) {
    .lightbox-panel {
      width: min(94vw, 440px);
    }

    .lightbox-close {
      top: -12px;
      right: -12px;
    }
  }
</style>
