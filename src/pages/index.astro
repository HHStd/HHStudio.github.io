---
import Base from '../layouts/Base.astro';
import { app, site } from '../data/site.js';
---

<Base
  title="HHStudio"
  description="HHStudio ana sayfası. Vaktio+ öne çıkan uygulama."
  image={site.ogImage}
  locale="tr"
>
  <main class="home">
    <p class="eyebrow">HHStudio</p>

    <a class="app-card panel" href={site.vaktioPath} aria-label="Vaktio+ sayfasına git">
      <img class="logo" src={app.icon} alt="" width="512" height="512" />
      <span class="app-name">Vaktio+</span>
    </a>
  </main>
</Base>

<style>
  .home {
    display: grid;
    min-height: calc(100vh - 120px);
    place-items: center;
    gap: 14px;
  }

  .eyebrow {
    margin: 0;
    color: var(--accent);
    font-size: 12px;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: none;
  }

  .app-card {
    width: min(420px, 100%);
    min-height: 124px;
    padding: 18px 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    text-align: left;
  }

  .logo {
    width: 58px;
    height: 58px;
    flex: 0 0 auto;
    border-radius: 16px;
    box-shadow: 0 18px 36px rgba(0, 0, 0, 0.28);
  }

  .app-name {
    font-size: clamp(1.7rem, 5vw, 2.2rem);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .app-card:hover {
    transform: translateY(-2px);
  }

  .app-card:focus-visible {
    outline: 2px solid rgba(47, 167, 255, 0.9);
    outline-offset: 3px;
  }

  .app-card,
  .app-card:hover {
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .app-card:hover {
    box-shadow: 0 26px 56px rgba(0, 0, 0, 0.36);
  }

  .app-card {
    border-radius: var(--radius-lg);
    background:
      radial-gradient(circle at top right, rgba(24, 213, 225, 0.1), transparent 35%),
      rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .app-card:visited {
    color: inherit;
  }

  .app-card {
    color: inherit;
    text-decoration: none;
  }

  .app-name {
    color: var(--text);
  }
</style>
