---
import Base from '../../layouts/Base.astro';
import { copy, site } from '../../data/site.js';

const locale = site.defaultLocale;
const text = copy[locale].androidTest;
---

<Base
  title={text.pageTitle}
  description={text.pageDescription}
  image={site.ogImage}
  locale={locale}
  translations={copy}
  titleKey="androidTest.pageTitle"
  descriptionKey="androidTest.pageDescription"
>
  <header class="page-head">
    <a class="back" href={site.homePath} data-i18n="androidTest.back">{text.back}</a>
    <span class="eyebrow" data-i18n="androidTest.eyebrow">{text.eyebrow}</span>
  </header>

  <main class="test panel">
    <div class="hero">
      <h1 data-i18n="androidTest.title">{text.title}</h1>
      <p class="lede" data-i18n="androidTest.lede">{text.lede}</p>
      <p class="intro" data-i18n="androidTest.intro">{text.intro}</p>
    </div>

    <section class="section-head">
      <h2 data-i18n="androidTest.flowHeading">{text.flowHeading}</h2>
    </section>

    <section class="flow-list">
      {text.flow.map((item, index) => (
        <article class="flow-card">
          <div class="flow-number" data-i18n={`androidTest.flow.${index}.step`}>
            {item.step}
          </div>
          <div class="flow-content">
            <h3 data-i18n={`androidTest.flow.${index}.title`}>{item.title}</h3>
            <p data-i18n={`androidTest.flow.${index}.description`}>{item.description}</p>
            <span class="flow-note" data-i18n={`androidTest.flow.${index}.note`}>{item.note}</span>
          </div>
          <a
            class="button button-primary"
            href={item.href}
            rel="noopener noreferrer"
            target="_blank"
            data-i18n={`androidTest.flow.${index}.cta`}
            data-i18n-attrs={JSON.stringify({ href: `androidTest.flow.${index}.href` })}
          >
            {item.cta}
          </a>
        </article>
      ))}
    </section>

    <section class="copy-card wide">
      <h2 data-i18n="androidTest.focusHeading">{text.focusHeading}</h2>
      <ul class="focus-list">
        {text.focus.map((item, index) => (
          <li data-i18n={`androidTest.focus.${index}`}>{item}</li>
        ))}
      </ul>
    </section>

    <section class="copy-card note">
      <h2 data-i18n="androidTest.noteHeading">{text.noteHeading}</h2>
      <p data-i18n="androidTest.note">{text.note}</p>
    </section>
  </main>
</Base>

<style>
  .page-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .back {
    color: var(--muted);
    font-size: 14px;
    font-weight: 700;
  }

  .test {
    padding: 22px;
  }

  .hero h1 {
    margin: 10px 0 12px;
    font-size: clamp(2.2rem, 6vw, 3.9rem);
    line-height: 0.96;
    letter-spacing: -0.06em;
  }

  .lede,
  .intro,
  .group-card p,
  .copy-card p,
  .copy-card li,
  .link-row small {
    color: var(--muted);
    line-height: 1.7;
  }

  .lede {
    margin: 0;
    max-width: 66ch;
    font-size: 17px;
  }

  .intro {
    margin: 14px 0 0;
    max-width: 62ch;
  }

  .section-head,
  .copy-card {
    margin-top: 18px;
  }

  .section-head h2,
  .copy-card h2 {
    margin: 0 0 8px;
    font-size: 18px;
  }

  .flow-list {
    display: grid;
    gap: 14px;
    margin-top: 18px;
  }

  .flow-card,
  .copy-card {
    padding: 18px;
    border-radius: var(--radius-md);
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .flow-card {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 18px 16px;
    align-items: start;
  }

  .flow-number {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: var(--accent);
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 0.06em;
    background: rgba(24, 213, 225, 0.08);
    border: 1px solid rgba(24, 213, 225, 0.18);
  }

  .flow-content {
    min-width: 0;
  }

  .flow-card h3 {
    margin: 0 0 8px;
    font-size: 20px;
  }

  .flow-card p,
  .flow-note,
  .copy-card p,
  .copy-card li {
    color: var(--muted);
    line-height: 1.7;
  }

  .flow-card p {
    margin: 0;
  }

  .flow-note {
    display: block;
    margin-top: 10px;
    font-size: 14px;
  }

  .flow-card .button {
    grid-column: 1 / -1;
    justify-self: start;
  }

  .copy-card {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .copy-card ol,
  .focus-list {
    margin: 0;
    padding-left: 18px;
  }

  .copy-card li + li,
  .focus-list li + li {
    margin-top: 8px;
  }

  .link-list {
    display: none;
  }

  .note {
    margin-top: 18px;
  }

  .wide {
    margin-top: 18px;
  }

  @media (min-width: 720px) {
    .test {
      padding: 26px;
    }

    .flow-card {
      grid-template-columns: auto minmax(0, 1fr) auto;
      align-items: center;
    }

    .flow-card .button {
      grid-column: auto;
    }
  }
</style>
